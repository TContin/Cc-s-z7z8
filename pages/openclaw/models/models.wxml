<view class="page-oc-models">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-inner">
      <view class="nav-back" bindtap="goBack"><text class="nav-back-icon">‹</text></view>
      <text class="nav-title">🤖 模型管理</text>
      <view class="nav-actions">
        <text class="nav-refresh {{refreshing ? 'spinning' : ''}}" bindtap="refreshAll">⟳</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content-scroll" style="top: {{navBarHeight}}px;" refresher-enabled bindrefresherrefresh="onPullRefresh" refresher-triggered="{{refreshing}}">

    <!-- 模型总数 + 操作 -->
    <view class="model-summary">
      <text class="model-summary-count">{{models.length}}</text>
      <text class="model-summary-label">个可用模型</text>
      <view class="model-probe-all" bindtap="probeAll" wx:if="{{models.length > 0 && !probing}}">
        <text class="probe-all-text">🔍 全部测试</text>
      </view>
      <view class="model-probe-all probing" wx:if="{{probing}}">
        <text class="probe-all-text">测试中 {{probeProgress}}/{{models.length}}</text>
      </view>
    </view>

    <!-- 当前会话使用的模型 -->
    <view class="current-model-card" wx:if="{{currentModel}}">
      <view class="current-model-header">
        <text class="current-model-title">当前模型</text>
        <view class="current-model-badge">
          <text class="current-model-name">{{currentModel}}</text>
        </view>
      </view>
      <text class="current-model-hint">点击下方模型可切换</text>
    </view>

    <!-- 模型列表 -->
    <view class="model-list" wx:if="{{models.length > 0}}">
      <view class="model-item {{item.id === currentModel ? 'active' : ''}}" wx:for="{{models}}" wx:key="id" bindtap="onModelTap" data-index="{{index}}">
        <view class="model-item-left">
          <view class="model-color-bar" style="background: {{item.color}};"></view>
          <view class="model-item-info">
            <view class="model-name-row">
              <text class="model-item-name">{{item.name}}</text>
              <text class="model-active-tag" wx:if="{{item.id === currentModel}}">当前</text>
            </view>
            <text class="model-item-provider">{{item.providerId || item.owned_by || 'unknown'}}</text>
            <view class="model-item-meta" wx:if="{{item.contextWindow}}">
              <text class="model-meta-tag">{{item.contextWindowText}} 上下文</text>
              <text class="model-meta-tag" wx:if="{{item.maxTokensText}}">{{item.maxTokensText}} 输出</text>
            </view>
          </view>
        </view>

        <view class="model-item-right">
          <!-- 探测状态 -->
          <view class="model-probe-badge {{item.probeClass}}" wx:if="{{item.probeStatus}}">
            <text class="model-probe-text">{{item.probeStatusText}}</text>
            <text class="model-probe-ms" wx:if="{{item.probeMs}}">{{item.probeMs}}ms</text>
          </view>

          <!-- 操作按钮 -->
          <view class="model-test-btn {{item.testing ? 'testing' : ''}}" catchtap="probeModel" data-index="{{index}}">
            <text class="model-test-text">{{item.testing ? '...' : '测试'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && models.length === 0}}">
      <text class="empty-icon">🤖</text>
      <text class="empty-text">暂无模型数据</text>
      <text class="empty-sub">请确保已启动 openclaw-api 服务</text>
    </view>

    <view class="model-note" wx:if="{{models.length > 0}}">
      <text class="model-note-text">💡 点击模型可切换当前默认模型。测试按钮会向模型发送极简请求验证可用性。</text>
    </view>

    <view style="height: 60rpx;"></view>
  </scroll-view>

  <!-- 切换模型确认弹窗 -->
  <view class="modal-mask" wx:if="{{showSwitchModal}}" bindtap="closeSwitchModal">
    <view class="modal-content" catchtap="">
      <text class="modal-title">切换模型</text>
      <text class="modal-desc">确定将默认模型切换为</text>
      <view class="modal-model-name">
        <view class="modal-model-dot" style="background: {{switchTarget.color}};"></view>
        <text class="modal-model-text">{{switchTarget.name}}</text>
      </view>
      <text class="modal-provider">{{switchTarget.providerId || ''}}</text>
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="closeSwitchModal">
          <text class="modal-btn-text">取消</text>
        </view>
        <view class="modal-btn confirm" bindtap="confirmSwitch">
          <text class="modal-btn-text confirm">确认切换</text>
        </view>
      </view>
    </view>
  </view>
</view>
