<view class="page-oc-models">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-inner">
      <view class="nav-back" bindtap="goBack"><text class="nav-back-icon">‹</text></view>
      <text class="nav-title">🤖 模型管理</text>
      <view class="nav-actions">
        <text class="nav-refresh {{refreshing ? 'spinning' : ''}}" bindtap="refreshAll">⟳</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="content-scroll" style="top: {{navBarHeight}}px;" refresher-enabled bindrefresherrefresh="onPullRefresh" refresher-triggered="{{refreshing}}">

    <!-- 模型总数 -->
    <view class="model-summary">
      <text class="model-summary-count">{{models.length}}</text>
      <text class="model-summary-label">个可用模型</text>
      <view class="model-probe-all" bindtap="probeAll" wx:if="{{models.length > 0 && !probing}}">
        <text class="probe-all-text">🔍 全部测试</text>
      </view>
      <view class="model-probe-all probing" wx:if="{{probing}}">
        <text class="probe-all-text">测试中 {{probeProgress}}/{{models.length}}</text>
      </view>
    </view>

    <!-- 模型列表 -->
    <view class="model-list" wx:if="{{models.length > 0}}">
      <view class="model-item" wx:for="{{models}}" wx:key="id">
        <view class="model-item-left">
          <view class="model-color-bar" style="background: {{item.color}};"></view>
          <view class="model-item-info">
            <text class="model-item-name">{{item.name}}</text>
            <text class="model-item-provider">{{item.owned_by || 'unknown'}}</text>
          </view>
        </view>

        <view class="model-item-right">
          <!-- 探测状态 -->
          <view class="model-probe-badge {{item.probeClass}}" wx:if="{{item.probeStatus}}">
            <text class="model-probe-text">{{item.probeStatusText}}</text>
            <text class="model-probe-ms" wx:if="{{item.probeMs}}">{{item.probeMs}}ms</text>
          </view>

          <!-- 测试按钮 -->
          <view class="model-test-btn {{item.testing ? 'testing' : ''}}" bindtap="probeModel" data-index="{{index}}">
            <text class="model-test-text">{{item.testing ? '...' : '测试'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && models.length === 0}}">
      <text class="empty-icon">🤖</text>
      <text class="empty-text">暂无模型数据</text>
      <text class="empty-sub">请确保 OpenClaw Gateway 已配置模型</text>
    </view>

    <!-- 模型说明 -->
    <view class="model-note" wx:if="{{models.length > 0}}">
      <text class="model-note-text">💡 测试通过向模型发送极简请求验证可用性。\n模型列表来自 Gateway 的 /v1/models 端点。</text>
    </view>

    <view style="height: 60rpx;"></view>
  </scroll-view>
</view>
