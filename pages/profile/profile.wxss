.page-profile {
  padding: 0 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 头部 */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 24rpx;
}

.avatar {
  font-size: 72rpx;
  width: 120rpx;
  height: 120rpx;
  background: var(--bg-card);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.app-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.app-ver {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx 16rpx;
  margin-bottom: 8rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
}

/* iOS 分组列表 */
.ios-group {
  background: var(--bg-card);
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 8rpx;
}

.ios-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  position: relative;
}

.ios-cell::after {
  content: '';
  position: absolute;
  left: 84rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: var(--separator);
}

.ios-cell:last-child::after {
  display: none;
}

.cell-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cell-icon-sm {
  font-size: 32rpx;
}

.cell-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.danger-text {
  color: var(--danger);
}

.cell-arrow {
  font-size: 34rpx;
  color: rgba(60, 60, 67, 0.3);
  font-weight: 300;
}
