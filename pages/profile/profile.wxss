.page-profile {
  padding: 0 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ===== 头部 - 已登录 ===== */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 28rpx;
}

.avatar-img {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
  background: var(--bg-card);
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.logout-link {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== 头部 - 未登录 ===== */
.avatar-default {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 2rpx dashed rgba(60, 60, 67, 0.15);
}

.avatar-placeholder {
  font-size: 64rpx;
  opacity: 0.4;
}

.login-btn {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 6rpx;
}

.login-hint {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ===== 统计行 ===== */
.stats-row {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx 16rpx;
  margin-bottom: 8rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
}

/* ===== iOS 分组列表 ===== */
.ios-group {
  background: var(--bg-card);
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 8rpx;
}

.ios-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  position: relative;
  min-height: 48rpx;
}

.ios-cell::after {
  content: '';
  position: absolute;
  left: 84rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: var(--separator);
}

.ios-cell:last-child::after {
  display: none;
}

.cell-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  overflow: hidden;
}

.cell-icon-sm {
  font-size: 32rpx;
  flex-shrink: 0;
}

.cell-text {
  font-size: 30rpx;
  color: var(--text-primary);
}

.cell-text-group {
  display: flex;
  flex-direction: column;
}

.cell-desc {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
}

.danger-text {
  color: var(--danger);
}

.cell-arrow {
  font-size: 34rpx;
  color: rgba(60, 60, 67, 0.3);
  font-weight: 300;
  flex-shrink: 0;
}

.cell-loading {
  font-size: 24rpx;
  color: var(--primary);
  flex-shrink: 0;
}

/* ===== 底部版本号 ===== */
.version-footer {
  text-align: center;
  padding: 32rpx 0 16rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}
