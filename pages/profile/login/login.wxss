.page-login {
  padding: 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.login-header {
  text-align: center;
  padding: 60rpx 0 48rpx;
}

.login-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.login-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-hint);
}

.form-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 24rpx;
}

/* 头像 */
.avatar-section {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 32rpx;
  border-bottom: 1rpx solid var(--separator);
}

.avatar-btn {
  width: 180rpx;
  height: 180rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  line-height: normal;
}

.avatar-btn::after {
  border: none;
}

.avatar-preview {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
}

.avatar-empty {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: var(--bg-page);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(60, 60, 67, 0.2);
}

.avatar-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.avatar-text {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 昵称 */
.nickname-section {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.nick-label {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-right: 24rpx;
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  text-align: right;
}

/* 提示 */
.login-tip {
  text-align: center;
  padding: 0 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.login-tip text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.confirm-btn {
  margin-top: 8rpx;
}
