<view class="page-profile">
  <!-- ===== 头部：登录 / 用户信息 ===== -->

  <!-- 已登录 -->
  <view class="profile-header" wx:if="{{isLoggedIn && userInfo}}">
    <image class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    <view class="user-name">{{userInfo.nickName}}</view>
    <view class="logout-link" bindtap="onLogout">退出登录</view>
  </view>

  <!-- 未登录 -->
  <view class="profile-header" wx:else>
    <view class="avatar-default" bindtap="onLogin">
      <text class="avatar-placeholder">👤</text>
    </view>
    <view class="login-btn" bindtap="onLogin">点击登录</view>
    <view class="login-hint">登录后可使用云同步功能</view>
  </view>

  <!-- ===== 数据概览 ===== -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.passwords}}</text>
      <text class="stat-label">密码</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.subscriptions}}</text>
      <text class="stat-label">订阅</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.storageSize}}</text>
      <text class="stat-label">存储</text>
    </view>
  </view>

  <!-- ===== 安全 ===== -->
  <view class="section-title">安全</view>
  <view class="ios-group">
    <view class="ios-cell">
      <view class="cell-left">
        <text class="cell-icon-sm">🔒</text>
        <text class="cell-text">密码保护</text>
      </view>
      <switch checked="{{settings.passwordProtect}}" color="#34C759" bindchange="onPasswordProtectChange" />
    </view>
    <view class="ios-cell" bindtap="onSecurityTap" wx:if="{{settings.passwordProtect}}">
      <view class="cell-left">
        <text class="cell-icon-sm">🔑</text>
        <text class="cell-text">修改密码</text>
      </view>
      <text class="cell-arrow">›</text>
    </view>
    <view class="ios-cell">
      <view class="cell-left">
        <text class="cell-icon-sm">☁️</text>
        <view class="cell-text-group">
          <text class="cell-text">云端同步</text>
          <text class="cell-desc">{{settings.cloudSync ? '数据变更时自动上传' : '开启后数据将上传到云端'}}</text>
        </view>
      </view>
      <switch checked="{{settings.cloudSync}}" color="#34C759" bindchange="onCloudSyncChange" />
    </view>
  </view>

  <!-- ===== 数据 ===== -->
  <view class="section-title">数据</view>
  <view class="ios-group">
    <view class="ios-cell" bindtap="onSyncFromCloud">
      <view class="cell-left">
        <text class="cell-icon-sm">🔄</text>
        <view class="cell-text-group">
          <text class="cell-text">同步数据</text>
          <text class="cell-desc">从云端拉取覆盖本地</text>
        </view>
      </view>
      <text class="cell-arrow" wx:if="{{!syncing}}">›</text>
      <text class="cell-loading" wx:else>同步中...</text>
    </view>
    <view class="ios-cell" bindtap="onExportData">
      <view class="cell-left">
        <text class="cell-icon-sm">📤</text>
        <text class="cell-text">导出数据摘要</text>
      </view>
      <text class="cell-arrow">›</text>
    </view>
    <view class="ios-cell" bindtap="onClearData">
      <view class="cell-left">
        <text class="cell-icon-sm">🗑️</text>
        <text class="cell-text danger-text">清除全部数据</text>
      </view>
      <text class="cell-arrow">›</text>
    </view>
  </view>

  <!-- ===== 其他 ===== -->
  <view class="section-title">其他</view>
  <view class="ios-group">
    <view class="ios-cell" bindtap="onAboutTap">
      <view class="cell-left">
        <text class="cell-icon-sm">ℹ️</text>
        <text class="cell-text">关于</text>
      </view>
      <text class="cell-arrow">›</text>
    </view>
  </view>

  <view class="version-footer">v{{version}}</view>
</view>
