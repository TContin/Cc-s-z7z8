<view class="page-profile">
  <!-- 头部 -->
  <view class="profile-header">
    <view class="avatar">🛠️</view>
    <view class="app-name">私人工具箱</view>
    <view class="app-ver">v{{version}}</view>
  </view>

  <!-- 数据 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{stats.passwords}}</text>
      <text class="stat-label">密码</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.subscriptions}}</text>
      <text class="stat-label">订阅</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.storageSize}}</text>
      <text class="stat-label">存储</text>
    </view>
  </view>

  <!-- 安全 -->
  <view class="section-title">安全</view>
  <view class="ios-group">
    <view class="ios-cell">
      <view class="cell-left">
        <text class="cell-icon-sm">🔒</text>
        <text class="cell-text">密码保护</text>
      </view>
      <switch checked="{{settings.passwordProtect}}" color="#34C759" bindchange="onPasswordProtectChange" />
    </view>
    <view class="ios-cell" bindtap="onSecurityTap" wx:if="{{settings.passwordProtect}}">
      <view class="cell-left">
        <text class="cell-icon-sm">🔑</text>
        <text class="cell-text">修改密码</text>
      </view>
      <text class="cell-arrow">›</text>
    </view>
  </view>

  <!-- 数据 -->
  <view class="section-title">数据</view>
  <view class="ios-group">
    <view class="ios-cell" bindtap="onExportData">
      <view class="cell-left">
        <text class="cell-icon-sm">📤</text>
        <text class="cell-text">导出数据摘要</text>
      </view>
      <text class="cell-arrow">›</text>
    </view>
    <view class="ios-cell" bindtap="onClearData">
      <view class="cell-left">
        <text class="cell-icon-sm">🗑️</text>
        <text class="cell-text danger-text">清除全部数据</text>
      </view>
      <text class="cell-arrow">›</text>
    </view>
  </view>

  <!-- 其他 -->
  <view class="section-title">其他</view>
  <view class="ios-group">
    <view class="ios-cell" bindtap="onAboutTap">
      <view class="cell-left">
        <text class="cell-icon-sm">ℹ️</text>
        <text class="cell-text">关于</text>
      </view>
      <text class="cell-arrow">›</text>
    </view>
  </view>
</view>
