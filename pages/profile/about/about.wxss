.page-about {
  padding: 16rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 24rpx;
}

.about-logo {
  font-size: 88rpx;
  margin-bottom: 12rpx;
}

.about-name {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.about-ver {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.about-desc {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 28rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.feature-list {
  background: var(--bg-card);
  border-radius: var(--radius);
  overflow: hidden;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  position: relative;
}

.feature-item::after {
  content: '';
  position: absolute;
  left: 88rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: var(--separator);
}

.feature-item:last-child::after {
  display: none;
}

.feature-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.feature-info {
  flex: 1;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 2rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: var(--text-hint);
}

.about-footer {
  text-align: center;
  padding: 40rpx 0 24rpx;
}

.share-btn {
  margin-bottom: 24rpx;
}

.footer-text {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
}
