<view class="page-about">
  <view class="about-header">
    <view class="about-logo">🛠️</view>
    <view class="about-name">私人工具箱</view>
    <view class="about-ver">版本 {{version}}</view>
  </view>

  <view class="about-desc">
    <text>一款为个人打造的实用工具合集，帮你安全管理密码、追踪订阅到期，让生活更有条理。</text>
  </view>

  <view class="section-title">功能特性</view>
  <view class="feature-list">
    <view class="feature-item" wx:for="{{features}}" wx:key="name">
      <text class="feature-icon">{{item.icon}}</text>
      <view class="feature-info">
        <view class="feature-name">{{item.name}}</view>
        <view class="feature-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="about-footer">
    <button class="btn-secondary share-btn" open-type="share">推荐给朋友</button>
    <view class="footer-text">数据仅存储在本机，卸载后将丢失</view>
    <view class="footer-text">请定期导出重要数据备份</view>
  </view>
</view>
