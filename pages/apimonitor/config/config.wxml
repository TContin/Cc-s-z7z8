<view class="page-config">
  <view class="form-card">
    <view class="form-row">
      <view class="form-row-label">名称</view>
      <input class="form-row-input" placeholder="如：AI Code With" value="{{name}}" data-field="name" bindinput="onInput" />
    </view>
    <view class="form-row">
      <view class="form-row-label">User ID</view>
      <input class="form-row-input mono" placeholder="从URL中获取的userId参数" value="{{userId}}" data-field="userId" bindinput="onInput" />
    </view>
    <view class="form-row">
      <view class="form-row-label">Cookie</view>
      <textarea class="form-row-textarea" placeholder="从浏览器开发者工具复制" value="{{cookie}}" data-field="cookie" bindinput="onInput" auto-height maxlength="-1" />
    </view>
  </view>

  <view class="tip-card">
    <text class="tip-title">如何获取？</text>
    <text class="tip-text">1. 浏览器登录 aicodewith.com 后台</text>
    <text class="tip-text">2. 按 F12 打开开发者工具 → Network</text>
    <text class="tip-text">3. 刷新页面，点击 usage-summary 请求</text>
    <text class="tip-text">4. User ID：请求URL中 userId= 后面的值</text>
    <text class="tip-text">5. Cookie：请求标头中 Cookie 字段的完整值</text>
    <text class="tip-text tip-warn">⚠️ Cookie 会过期，过期后需要重新获取</text>
    <text class="tip-text tip-warn">⚠️ 数据仅存储在本地，不会上传</text>
  </view>

  <button class="btn-primary" bindtap="onSave">{{isEdit ? '保存修改' : '保存配置'}}</button>
  <button class="btn-danger del-btn" wx:if="{{isEdit}}" bindtap="onDelete">删除配置</button>
</view>
