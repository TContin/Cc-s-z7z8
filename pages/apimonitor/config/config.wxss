.page-config {
  padding: 16rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.form-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.form-row:last-child {
  border-bottom: none;
}

.form-row-label {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.form-row-input {
  width: 100%;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 4rpx 0;
}

.form-row-input.mono {
  font-family: monospace;
  font-size: 26rpx;
}

.form-row-textarea {
  width: 100%;
  font-size: 24rpx;
  color: var(--text-primary);
  padding: 8rpx 0;
  min-height: 160rpx;
  font-family: monospace;
  word-break: break-all;
}

.tip-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 2;
}

.tip-warn {
  color: var(--warning);
  margin-top: 8rpx;
}

.del-btn {
  margin-top: 16rpx;
}
