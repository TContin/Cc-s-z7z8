.page-config {
  padding: 16rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 云端同步 */
.sync-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.sync-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.sync-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: var(--bg-page);
  border-radius: 16rpx;
}

.sync-btn.primary {
  background: rgba(0, 122, 255, 0.08);
}

.sync-icon {
  font-size: 28rpx;
}

.sync-text {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.sync-btn.primary .sync-text {
  color: var(--primary);
}

.sync-hint {
  font-size: 22rpx;
  color: var(--text-hint);
  text-align: center;
  display: block;
}

.form-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.form-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.form-row:last-child {
  border-bottom: none;
}

.form-row-label {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.form-row-input {
  width: 100%;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 4rpx 0;
}

.form-row-input.mono {
  font-family: monospace;
  font-size: 26rpx;
}

.form-row-textarea {
  width: 100%;
  font-size: 24rpx;
  color: var(--text-primary);
  padding: 8rpx 0;
  min-height: 160rpx;
  font-family: monospace;
  word-break: break-all;
}

.tip-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 2;
}

.tip-warn {
  color: var(--warning);
  margin-top: 8rpx;
}

.del-btn {
  margin-top: 16rpx;
}
