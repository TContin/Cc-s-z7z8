.page-config {
  padding: 16rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 预设列表 */
.preset-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.preset-item {
  padding: 12rpx 24rpx;
  background: var(--bg-card);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.preset-item.active {
  background: var(--primary);
  color: #fff;
}

/* 表单 */
.form-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.form-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.form-row:last-child {
  border-bottom: none;
}

.form-row-label {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.form-row-input {
  width: 100%;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 4rpx 0;
}

.form-row-input.mono {
  font-family: monospace;
}

/* 提示 */
.tip-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx 32rpx;
  margin-bottom: 32rpx;
}

.tip-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 1.8;
}

.del-btn {
  margin-top: 16rpx;
}
