.page-home {
  padding: 0 32rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* iOS 大标题头部 */
.header {
  padding: 16rpx 0 24rpx;
}

.header-date {
  font-size: 26rpx;
  color: var(--text-hint);
  font-weight: 400;
}

.header-greeting {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

/* 概览行 */
.overview {
  display: flex;
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 28rpx 16rpx;
  margin-bottom: 8rpx;
}

.overview-item {
  flex: 1;
  text-align: center;
}

.overview-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.overview-num.warn {
  color: var(--warning);
}

.overview-num.danger {
  color: var(--danger);
}

.overview-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

/* iOS 分组列表 */
.ios-group {
  background: var(--bg-card);
  border-radius: var(--radius);
  overflow: hidden;
}

.ios-cell {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  position: relative;
}

.ios-cell::after {
  content: '';
  position: absolute;
  left: 116rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: var(--separator);
}

.ios-cell:last-child::after {
  display: none;
}

.cell-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.cell-body {
  flex: 1;
  margin-left: 24rpx;
}

.cell-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.cell-desc {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
}

.cell-arrow {
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 36rpx;
  color: rgba(60, 60, 67, 0.3);
  font-weight: 300;
}

/* 底部 */
.home-footer {
  text-align: center;
  padding: 48rpx 0 20rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}
