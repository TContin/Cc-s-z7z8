.page-config {
  padding: 16rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.form-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.form-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.form-row:last-child { border-bottom: none; }

.form-row-label {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.form-row-input {
  width: 100%;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 4rpx 0;
}

.form-row-input.mono {
  font-family: monospace;
  font-size: 26rpx;
}

.picker-value {
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 8rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow { color: var(--text-hint); font-size: 24rpx; }

/* 测试状态 */
.test-status {
  padding: 20rpx 24rpx;
  border-radius: var(--radius);
  margin-bottom: 16rpx;
  font-size: 26rpx;
}

.test-status.test-success {
  background: rgba(52, 199, 89, 0.1);
  color: var(--success);
}

.test-status.test-fail {
  background: rgba(255, 59, 48, 0.1);
  color: var(--danger);
}

.test-status:not(.test-success):not(.test-fail) {
  background: rgba(255, 149, 0, 0.1);
  color: var(--warning);
}

.tip-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.tip-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  line-height: 2;
}

.tip-warn { color: var(--warning); margin-top: 8rpx; }
.tip-info { color: var(--success); margin-top: 8rpx; }

.save-btn { margin-top: 16rpx; }
.del-btn { margin-top: 16rpx; }
