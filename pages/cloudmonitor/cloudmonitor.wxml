<view class="page-cloud">
  <!-- 未配置 -->
  <view class="empty-state" wx:if="{{!configured}}">
    <text class="empty-icon">☁️</text>
    <text class="empty-text">尚未配置腾讯云</text>
    <text class="empty-sub">需要配置 SecretId 和 SecretKey</text>
    <button class="btn-primary setup-btn" bindtap="onConfigTap">去配置</button>
  </view>

  <block wx:else>
    <view class="top-bar">
      <view class="top-left">
        <text class="top-title">云服务监控</text>
        <text class="top-time" wx:if="{{lastUpdate}}">{{lastUpdate}} 更新</text>
      </view>
      <view class="top-actions">
        <text class="action-btn" bindtap="onRefresh">{{refreshing ? '...' : '刷新'}}</text>
        <text class="action-btn" bindtap="onConfigTap">设置</text>
      </view>
    </view>

    <view class="loading-state" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <block wx:else>
      <!-- ===== 账户余额 ===== -->
      <view class="balance-card" wx:if="{{balance}}">
        <view class="bal-top">
          <text class="bal-label">账户余额</text>
          <text class="bal-amount {{balance.total < 10 ? 'low' : ''}}">¥{{balance.total}}</text>
        </view>
        <view class="bal-detail">
          <view class="bal-item"><text class="bal-item-val">¥{{balance.cash}}</text><text class="bal-item-label">现金</text></view>
          <view class="bal-item"><text class="bal-item-val">¥{{balance.gift}}</text><text class="bal-item-label">赠送</text></view>
          <view class="bal-item"><text class="bal-item-val">¥{{balance.frozen}}</text><text class="bal-item-label">冻结</text></view>
          <view class="bal-item" wx:if="{{balance.owe !== '0.00'}}"><text class="bal-item-val low">¥{{balance.owe}}</text><text class="bal-item-label">欠费</text></view>
        </view>
      </view>

      <!-- ===== 用量与监控 (仿腾讯云) ===== -->
      <block wx:if="{{instances.length > 0}}">
        <view class="monitor-card">
          <view class="monitor-header">
            <text class="monitor-title">用量与监控</text>
            <view class="inst-tag">
              <text class="tag {{instances[0].status === 'RUNNING' ? 'tag-success' : 'tag-danger'}}">
                {{instances[0].status === 'RUNNING' ? '运行中' : instances[0].status}}
              </text>
            </view>
          </view>

          <!-- 服务器基本信息 -->
          <view class="inst-info-row">
            <text class="inst-info-name">{{instances[0].name}}</text>
            <text class="inst-info-ip">{{instances[0].publicIp}}</text>
          </view>

          <!-- 指标网格 6列 -->
          <view class="metric-grid">
            <!-- 流量包（圆环） -->
            <view class="metric-cell ring-cell">
              <text class="metric-label">流量包</text>
              <view class="ring-wrap">
                <view class="ring" style="background: conic-gradient(var(--primary) {{trafficRing.percent * 3.6}}deg, #F0F0F0 0deg);">
                  <view class="ring-inner">
                    <text class="ring-pct">{{trafficRing.percent}}%</text>
                  </view>
                </view>
              </view>
              <text class="metric-big">{{trafficRing.used}}</text>
              <text class="metric-sub">/{{trafficRing.total}}</text>
            </view>

            <!-- 系统盘（圆环） -->
            <view class="metric-cell ring-cell">
              <text class="metric-label">系统盘</text>
              <view class="ring-wrap">
                <view class="ring" style="background: conic-gradient(var(--success) {{diskRing.percent * 3.6}}deg, #F0F0F0 0deg);">
                  <view class="ring-inner">
                    <text class="ring-pct">{{diskRing.percent > 0 ? diskRing.percent + '%' : '--'}}</text>
                  </view>
                </view>
              </view>
              <text class="metric-big">{{diskRing.used}}</text>
              <text class="metric-sub">/{{diskRing.total}}</text>
            </view>

            <!-- CPU -->
            <view class="metric-cell">
              <text class="metric-label">CPU | {{instances[0].cpu}}核</text>
              <text class="metric-big">{{monitor.cpuPercent || '--'}}<text class="metric-unit"> %</text></text>
              <view class="mini-bar"><view class="mini-bar-fill" style="width: {{monitor.cpuPercent || 0}}%"></view></view>
            </view>

            <!-- 内存 -->
            <view class="metric-cell">
              <text class="metric-label">内存 | {{instances[0].memory}}GB</text>
              <text class="metric-big">{{monitor.memUsedMB || '--'}}<text class="metric-unit"> MB</text></text>
              <view class="mini-bar"><view class="mini-bar-fill mem" style="width: {{monitor.memPercent || 0}}%"></view></view>
            </view>

            <!-- 公网带宽 -->
            <view class="metric-cell">
              <text class="metric-label">公网带宽</text>
              <view class="bw-row">
                <text class="bw-dir">入</text>
                <text class="bw-val">{{monitor.bandwidthInMbps || '0'}} Mbps</text>
              </view>
              <view class="bw-row">
                <text class="bw-dir">出</text>
                <text class="bw-val">{{monitor.bandwidthOutMbps || '0'}} Mbps</text>
              </view>
            </view>

            <!-- TCP 连接 -->
            <view class="metric-cell">
              <text class="metric-label">TCP 连接</text>
              <text class="metric-big">{{monitor.tcpConnections != null ? monitor.tcpConnections : '--'}}</text>
              <text class="metric-sub">当前活跃连接数</text>
            </view>
          </view>

          <!-- 到期/流量重置 -->
          <view class="monitor-footer">
            <text class="footer-text" wx:if="{{trafficRing.resetTime}}">流量包重置: {{trafficRing.resetTime}}</text>
            <text class="footer-text">到期: {{instances[0].expiredTime}}</text>
          </view>
        </view>
      </block>

      <!-- ===== 多台服务器列表（第2台起） ===== -->
      <block wx:if="{{instances.length > 1}}">
        <view class="section-title">其他服务器</view>
        <view class="ios-group">
          <view class="inst-item" wx:for="{{instances}}" wx:if="{{index > 0}}" wx:key="id">
            <view class="inst-row">
              <text class="inst-name2">{{item.name}}</text>
              <text class="tag {{item.status === 'RUNNING' ? 'tag-success' : 'tag-danger'}}">{{item.status === 'RUNNING' ? '运行中' : item.status}}</text>
            </view>
            <view class="inst-row">
              <text class="inst-spec2">{{item.publicIp}} · {{item.cpu}}核{{item.memory}}G · {{item.diskSize}}GB</text>
            </view>
            <view class="inst-row">
              <text class="inst-expire2">到期 {{item.expiredTime}}</text>
              <text class="inst-traffic2" wx:if="{{item.trafficTotalGB > 0}}">流量 {{item.trafficPercent}}%</text>
            </view>
          </view>
        </view>
      </block>

      <!-- ===== 域名 ===== -->
      <view class="section-title" wx:if="{{domains.length > 0}}">域名（{{domains.length}}个）</view>
      <view class="ios-group" wx:if="{{domains.length > 0}}">
        <view class="domain-item" wx:for="{{domains}}" wx:key="name">
          <view class="domain-left">
            <text class="domain-name">{{item.name}}</text>
            <text class="domain-expire">到期 {{item.expiredDate || '--'}}</text>
          </view>
          <text class="tag tag-{{item.statusType}}">{{item.statusText}}</text>
        </view>
      </view>

      <!-- ===== SSL 证书 ===== -->
      <view class="section-title" wx:if="{{certificates.length > 0}}">SSL 证书（{{certificates.length}}个）</view>
      <view class="ios-group" wx:if="{{certificates.length > 0}}">
        <view class="cert-item" wx:for="{{certificates}}" wx:key="id">
          <view class="cert-left">
            <text class="cert-domain">{{item.domain}}</text>
            <text class="cert-product">{{item.productName || '免费证书'}}</text>
          </view>
          <text class="tag tag-{{item.statusType}}">{{item.statusText}}</text>
        </view>
      </view>

      <!-- 错误提示 -->
      <view class="error-card" wx:if="{{errors && (errors.instances || errors.domains || errors.certificates || errors.balance)}}">
        <text class="error-title">部分数据获取失败</text>
        <text class="error-text" wx:if="{{errors.instances}}">服务器: {{errors.instances}}</text>
        <text class="error-text" wx:if="{{errors.domains}}">域名: {{errors.domains}}</text>
        <text class="error-text" wx:if="{{errors.certificates}}">证书: {{errors.certificates}}</text>
        <text class="error-text" wx:if="{{errors.balance}}">余额: {{errors.balance}}</text>
        <text class="error-hint">请检查 API 密钥权限</text>
      </view>

      <view class="no-data" wx:if="{{!balance && instances.length === 0 && domains.length === 0 && certificates.length === 0}}">
        <text class="no-data-icon">☁️</text>
        <text class="no-data-text">暂无数据</text>
        <text class="no-data-sub">请检查 API 密钥配置和权限</text>
      </view>
    </block>
  </block>
</view>
