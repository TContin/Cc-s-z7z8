.page-cloud {
  padding: 16rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.setup-btn { width: 400rpx !important; margin-top: 32rpx; }

.top-bar { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0 20rpx; }
.top-title { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.top-time { font-size: 22rpx; color: var(--text-hint); margin-left: 12rpx; }
.top-actions { display: flex; gap: 20rpx; }
.action-btn { font-size: 26rpx; color: var(--primary); font-weight: 500; }

.loading-state { text-align: center; padding: 120rpx 0; }
.loading-text { font-size: 28rpx; color: var(--text-hint); }

/* 余额卡片 */
.balance-card {
  background: linear-gradient(135deg, #007AFF 0%, #409CFF 100%);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-bottom: 16rpx;
  color: #fff;
}
.bal-top { margin-bottom: 20rpx; }
.bal-label { font-size: 24rpx; opacity: 0.8; display: block; margin-bottom: 8rpx; }
.bal-amount { font-size: 56rpx; font-weight: 700; display: block; }
.bal-amount.danger { color: #FFD1D1; }
.bal-detail { display: flex; gap: 24rpx; }
.bal-item { display: flex; flex-direction: column; }
.bal-item-val { font-size: 28rpx; font-weight: 600; }
.bal-item-val.danger { color: #FFD1D1; }
.bal-item-label { font-size: 20rpx; opacity: 0.7; margin-top: 2rpx; }

/* iOS 分组 */
.ios-group { background: var(--bg-card); border-radius: var(--radius); overflow: hidden; margin-bottom: 8rpx; }

/* 服务器卡片 */
.inst-item { padding: 24rpx 28rpx; position: relative; }
.inst-item::after { content: ''; position: absolute; left: 28rpx; right: 0; bottom: 0; height: 1rpx; background: var(--separator); }
.inst-item:last-child::after { display: none; }

.inst-header { margin-bottom: 8rpx; }
.inst-name-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4rpx; }
.inst-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.inst-ip { font-size: 24rpx; color: var(--text-hint); font-family: monospace; }

.inst-specs { display: flex; align-items: center; font-size: 24rpx; color: var(--text-secondary); margin-bottom: 10rpx; }
.spec { font-weight: 500; }
.spec-sep { margin: 0 8rpx; color: var(--text-hint); }

/* 流量条 */
.traffic-row { margin-bottom: 10rpx; }
.traffic-bar-bg { height: 12rpx; background: rgba(0,0,0,0.06); border-radius: 6rpx; overflow: hidden; margin-bottom: 6rpx; }
.traffic-bar-fill { height: 100%; background: var(--primary); border-radius: 6rpx; transition: width 0.3s; }
.traffic-bar-fill.warning { background: var(--warning); }
.traffic-bar-fill.danger { background: var(--danger); }
.traffic-text { font-size: 22rpx; color: var(--text-hint); }

.inst-footer { display: flex; justify-content: space-between; }
.inst-os { font-size: 22rpx; color: var(--text-hint); max-width: 60%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.inst-expire { font-size: 22rpx; color: var(--text-hint); }

/* 域名 */
.domain-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 28rpx; position: relative; }
.domain-item::after { content: ''; position: absolute; left: 28rpx; right: 0; bottom: 0; height: 1rpx; background: var(--separator); }
.domain-item:last-child::after { display: none; }
.domain-left { flex: 1; }
.domain-name { font-size: 28rpx; font-weight: 500; color: var(--text-primary); display: block; }
.domain-expire { font-size: 22rpx; color: var(--text-hint); margin-top: 2rpx; display: block; }

/* 证书 */
.cert-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 28rpx; position: relative; }
.cert-item::after { content: ''; position: absolute; left: 28rpx; right: 0; bottom: 0; height: 1rpx; background: var(--separator); }
.cert-item:last-child::after { display: none; }
.cert-left { flex: 1; }
.cert-domain { font-size: 28rpx; font-weight: 500; color: var(--text-primary); display: block; }
.cert-product { font-size: 22rpx; color: var(--text-hint); margin-top: 2rpx; display: block; }

/* 错误提示 */
.error-card { background: rgba(255,59,48,0.06); border-radius: var(--radius); padding: 24rpx 28rpx; margin-top: 16rpx; }
.error-title { display: block; font-size: 26rpx; font-weight: 600; color: var(--danger); margin-bottom: 8rpx; }
.error-text { display: block; font-size: 22rpx; color: var(--text-secondary); line-height: 1.8; }
.error-hint { display: block; font-size: 22rpx; color: var(--text-hint); margin-top: 8rpx; }

.no-data { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.no-data-icon { font-size: 80rpx; margin-bottom: 16rpx; opacity: 0.5; }
.no-data-text { font-size: 28rpx; color: var(--text-hint); }
.no-data-sub { font-size: 24rpx; color: var(--text-hint); text-align: center; padding: 0 40rpx; }
