.page-edit {
  padding: 16rpx 32rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

/* 时间 */
.edit-time {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-hint);
  padding: 12rpx 0 24rpx;
}

/* 标题 - iOS 备忘录风格大标题 */
.edit-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 8rpx 0 16rpx;
  width: 100%;
  line-height: 1.3;
}

/* 正文 */
.edit-content {
  font-size: 32rpx;
  color: var(--text-primary);
  width: 100%;
  min-height: 400rpx;
  line-height: 1.8;
  padding: 0;
}

/* 底部工具栏 */
.toolbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  border-top: 1rpx solid var(--separator);
  z-index: 100;
}

.toolbar-left, .toolbar-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tool-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.tool-btn:active {
  background: rgba(0, 0, 0, 0.05);
}

.tool-btn.active {
  background: rgba(0, 122, 255, 0.1);
}

.word-count {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-right: 8rpx;
}

/* 文件夹选择面板 */
.folder-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 200;
  max-height: 60vh;
  overflow-y: auto;
}

.folder-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.folder-panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.folder-panel-close {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 500;
}

.folder-input-row {
  margin-bottom: 16rpx;
}

.folder-input {
  width: 100%;
  padding: 16rpx 20rpx;
  background: var(--bg-page);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.folder-option {
  padding: 20rpx 20rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border-radius: 12rpx;
}

.folder-option:active, .folder-option.active {
  background: rgba(0, 122, 255, 0.08);
  color: var(--primary);
}
