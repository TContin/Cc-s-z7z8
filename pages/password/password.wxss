.page-password {
  padding: 16rpx 32rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* 锁定屏幕 */
.lock-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 280rpx;
}

.lock-icon {
  font-size: 100rpx;
  margin-bottom: 28rpx;
  opacity: 0.6;
}

.lock-text {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.lock-sub {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 分类滚动 - iOS Chip */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.category-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  background: var(--bg-card);
  color: var(--text-secondary);
  font-weight: 400;
}

.category-tag.active {
  background: var(--primary);
  color: #fff;
  font-weight: 500;
}

/* 密码列表 - iOS grouped */
.password-list {
  background: var(--bg-card);
  border-radius: var(--radius);
  overflow: hidden;
}

.password-item {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
  position: relative;
}

.password-item::after {
  content: '';
  position: absolute;
  left: 116rpx;
  right: 0;
  bottom: 0;
  height: 1rpx;
  background: var(--separator);
}

.password-item:last-child::after {
  display: none;
}

.pw-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pw-icon {
  font-size: 32rpx;
}

.pw-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.pw-platform {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pw-account {
  font-size: 24rpx;
  color: var(--text-hint);
  margin-top: 2rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pw-category-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: var(--bg-page);
  color: var(--text-hint);
  flex-shrink: 0;
  margin-right: 8rpx;
}

.pw-arrow {
  font-size: 32rpx;
  color: rgba(60, 60, 67, 0.3);
  flex-shrink: 0;
}
