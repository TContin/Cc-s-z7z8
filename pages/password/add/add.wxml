<view class="page-add">
  <!-- 快速选择 -->
  <view class="template-toggle" bindtap="toggleTemplates">
    <text class="tpl-toggle-text">快速选择常用平台</text>
    <text class="tpl-toggle-arrow">{{showTemplates ? '收起' : '展开'}}</text>
  </view>

  <view class="template-grid" wx:if="{{showTemplates}}">
    <view class="template-item" wx:for="{{templates}}" wx:key="name" data-tpl="{{item}}" bindtap="onTemplateTap">
      <view class="brand-icon brand-icon-mini">
        <image wx:if="{{item.logo}}" class="brand-logo" src="{{item.logo}}" mode="aspectFit" />
        <text wx:else style="color:#fff">{{item.letter}}</text>
      </view>
      <text class="tpl-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 图标预览 -->
  <view class="icon-selector" bindtap="toggleIconPicker">
    <view class="brand-icon brand-icon-lg" style="background:{{iconLogo ? '#F2F2F7' : iconBg}}">
      <image wx:if="{{iconLogo}}" class="brand-logo" src="{{iconLogo}}" mode="aspectFit" />
      <text wx:else>{{iconLetter}}</text>
    </view>
    <text class="icon-hint">更换图标</text>
  </view>

  <view class="icon-picker" wx:if="{{showIconPicker}}">
    <view class="icon-option" wx:for="{{customIcons}}" wx:key="name" data-letter="{{item.letter}}" data-bg="{{item.bg}}" bindtap="onIconSelect">
      <view class="brand-icon" style="background:{{item.bg}};width:60rpx;height:60rpx;font-size:24rpx;border-radius:14rpx">{{item.letter}}</view>
    </view>
  </view>

  <!-- 表单 -->
  <view class="form-card">
    <view class="form-row">
      <view class="form-row-label">平台名称</view>
      <input class="form-row-input" placeholder="如：微信、GitHub" value="{{platform}}" data-field="platform" bindinput="onInput" />
    </view>
    <view class="form-row">
      <view class="form-row-label">账号</view>
      <input class="form-row-input" placeholder="用户名、手机号或邮箱" value="{{account}}" data-field="account" bindinput="onInput" />
    </view>
    <view class="form-row">
      <view class="form-row-label">密码</view>
      <view class="password-row">
        <input class="password-input" placeholder="输入密码" value="{{password}}" password="{{!showPassword}}" data-field="password" bindinput="onInput" />
        <view class="pw-actions">
          <text class="pw-toggle" bindtap="toggleShowPassword">{{showPassword ? '🙈' : '👁️'}}</text>
          <text class="pw-gen" bindtap="generatePassword">🎲</text>
        </view>
      </view>
    </view>
    <view class="form-row">
      <view class="form-row-label">分类</view>
      <picker mode="selector" range="{{categories}}" value="{{categoryIndex}}" bindchange="onCategoryChange">
        <view class="picker-row"><text class="picker-value">{{category}}</text><text class="picker-arrow">›</text></view>
      </picker>
    </view>
    <view class="form-row">
      <view class="form-row-label">网站地址</view>
      <input class="form-row-input" placeholder="https://..." value="{{website}}" data-field="website" bindinput="onInput" />
    </view>
    <view class="form-row">
      <view class="form-row-label">备注</view>
      <textarea class="form-row-textarea" placeholder="选填" value="{{remark}}" data-field="remark" bindinput="onInput" auto-height maxlength="500" />
    </view>
  </view>

  <button class="btn-primary save-btn" bindtap="onSave">{{isEdit ? '保存修改' : '保存'}}</button>
</view>
