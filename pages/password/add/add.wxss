.page-add {
  padding: 16rpx 32rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 快捷模板 */
.template-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  margin-bottom: 16rpx;
}

.tpl-toggle-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.tpl-toggle-arrow {
  font-size: 24rpx;
  color: var(--primary);
}

.template-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius);
  margin-bottom: 16rpx;
  max-height: 480rpx;
  overflow-y: auto;
}

.template-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  background: var(--bg-page);
  border-radius: 20rpx;
  font-size: 24rpx;
}

.tpl-icon {
  font-size: 24rpx;
}

.tpl-name {
  color: var(--text-primary);
}

/* 图标选择器 */
.icon-selector {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 0 20rpx;
}

.selected-icon {
  width: 108rpx;
  height: 108rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.icon-text {
  font-size: 52rpx;
}

.icon-hint {
  font-size: 22rpx;
  color: var(--primary);
}

.icon-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg-page);
  border-radius: 16rpx;
  margin: 0 32rpx 16rpx;
  justify-content: center;
}

.icon-option {
  font-size: 40rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: 16rpx;
}

/* iOS 表单卡片 */
.form-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.form-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.form-row:last-child {
  border-bottom: none;
}

.form-row-label {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 8rpx;
}

.form-row-input {
  width: 100%;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 4rpx 0;
}

.form-row-textarea {
  width: 100%;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 4rpx 0;
  min-height: 100rpx;
}

/* 密码行 */
.password-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.password-input {
  flex: 1;
  font-size: 30rpx;
  padding: 4rpx 0;
}

.pw-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.pw-toggle, .pw-gen {
  font-size: 36rpx;
  padding: 4rpx;
}

/* iOS 选择器行 */
.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}

.picker-value {
  font-size: 30rpx;
  color: var(--text-primary);
}

.picker-arrow {
  color: var(--text-hint);
  font-size: 24rpx;
}

/* 保存按钮 */
.save-btn {
  margin-top: 16rpx;
}
