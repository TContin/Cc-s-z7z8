<view class="page-password">
  <!-- 锁定状态 -->
  <view class="lock-screen" wx:if="{{isLocked}}">
    <view class="lock-icon">🔒</view>
    <view class="lock-text">密码本已锁定</view>
    <view class="lock-sub">请验证密码后访问</view>
  </view>

  <block wx:else>
    <!-- 搜索栏 -->
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索" 
        placeholder-style="color: #8E8E93"
        value="{{searchKey}}"
        bindinput="onSearchInput"
      />
    </view>

    <!-- 分类 -->
    <scroll-view scroll-x class="category-scroll" enhanced show-scrollbar="{{false}}">
      <view class="category-list">
        <view 
          class="category-tag {{currentCategory === item ? 'active' : ''}}"
          wx:for="{{categories}}"
          wx:key="*this"
          data-name="{{item}}"
          bindtap="onCategoryTap"
        >{{item}}</view>
      </view>
    </scroll-view>

    <!-- 列表 -->
    <view class="password-list" wx:if="{{!isEmpty}}">
      <view 
        class="password-item"
        wx:for="{{filteredList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onItemTap"
        bindlongpress="onItemLongpress"
      >
        <view class="brand-icon brand-icon-md" style="background:{{item.brandLogo ? '#F2F2F7' : item.brandBg}}">
          <image wx:if="{{item.brandLogo}}" class="brand-logo" src="{{item.brandLogo}}" mode="aspectFit" />
          <text wx:else>{{item.brandLetter}}</text>
        </view>
        <view class="pw-info">
          <view class="pw-platform">{{item.displayName}}</view>
          <view class="pw-account">{{item.displayAccount}}</view>
        </view>
        <text class="pw-category-tag">{{item.category || '其他'}}</text>
        <text class="pw-arrow">›</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{isEmpty}}">
      <text class="empty-icon">🔐</text>
      <text class="empty-text">{{searchKey ? '没有找到匹配记录' : '暂无密码记录'}}</text>
      <text class="empty-sub" wx:if="{{!searchKey}}">点击 + 添加第一条记录</text>
    </view>

    <view class="fab" bindtap="onAddTap">
      <text class="fab-icon">+</text>
    </view>
  </block>
</view>
